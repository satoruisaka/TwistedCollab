# TwistedCollab Environment Variables
# Copy this file to .env and fill in your values

# Brave Search API Key (get from https://brave.com/search/api/)
BRAVE_API_KEY="API key here"

# External data directories (WSL paths)
# (1) Reference papers directory (~823 PDFs)
# These are used for INITIAL index build only
# New papers added via API go to delta index automatically
MRA_REFERENCE_PAPERS_DIR="directory here"

# (3) Your authored papers directory (7 PDFs)
MRA_MY_PAPERS_DIR="directory here"

# Optional: Override default Ollama URL
# OLLAMA_URL=http://localhost:11434

# Optional: Override TwistedPair V2 URL
# TWISTEDPAIR_URL=http://localhost:8000

OLLAMA_KEEP_ALIVE=0

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
